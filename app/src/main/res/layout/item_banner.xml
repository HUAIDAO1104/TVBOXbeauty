<?xml version="1.0" encoding="utf-8"?>
<!-- 首页轮播图单个条目 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_banner_radius">

    <!-- 封面图（centerCrop：填满轮播图区域，高清无模糊） -->
    <ImageView
        android:id="@+id/ivBannerThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 底部渐变遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/vs_160"
        android:layout_gravity="bottom"
        android:background="@drawable/shape_banner_gradient" />

    <!-- 底部信息区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingLeft="@dimen/vs_30"
        android:paddingRight="@dimen/vs_30"
        android:paddingBottom="@dimen/vs_25">

        <!-- 标签行（分类/年份）-->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBannerType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/vs_8"
                android:background="@drawable/shape_tag_theme"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_10"
                android:paddingTop="@dimen/vs_3"
                android:paddingRight="@dimen/vs_10"
                android:paddingBottom="@dimen/vs_3"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_20" />

            <TextView
                android:id="@+id/tvBannerYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_thumb_year"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_10"
                android:paddingTop="@dimen/vs_3"
                android:paddingRight="@dimen/vs_10"
                android:paddingBottom="@dimen/vs_3"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_20" />

        </LinearLayout>

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvBannerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/ts_30"
            android:textStyle="bold"
            android:shadowColor="@color/color_000000_90"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="5" />

        <!-- 简介 -->
        <TextView
            android:id="@+id/tvBannerDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_5"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/color_FFFFFF_70"
            android:textSize="@dimen/ts_20"
            android:shadowColor="@color/color_000000_80"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />
    </LinearLayout>

</FrameLayout>
