<?xml version="1.0" encoding="utf-8"?>
<!-- 搜索结果缩略图卡片 - 美化版：圆角12mm、渐变底部 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_card_focus"
    android:focusable="true"
    android:padding="@dimen/vs_2">

    <FrameLayout
        android:layout_width="@dimen/vs_160"
        android:layout_height="@dimen/vs_240"
        android:clipChildren="true"
        android:clipToPadding="true">

        <!-- 封面图 -->
        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <!-- 底部渐变遮罩 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/vs_100"
            android:layout_gravity="bottom"
            android:background="@drawable/shape_card_gradient_bottom" />

        <!-- 来源标签（顶部左侧）-->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/vs_6"
            android:layout_marginLeft="@dimen/vs_6"
            android:layout_marginTop="@dimen/vs_6"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_tag_theme"
                android:ellipsize="end"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_5"
                android:paddingTop="@dimen/vs_2"
                android:paddingRight="@dimen/vs_5"
                android:paddingBottom="@dimen/vs_2"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_16" />

        </LinearLayout>

        <!-- 底部信息区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingLeft="@dimen/vs_8"
            android:paddingRight="@dimen/vs_8"
            android:paddingBottom="@dimen/vs_8">

            <!-- 更新进度标签 -->
            <TextView
                android:id="@+id/tvNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/vs_4"
                android:background="@drawable/shape_thumb_note"
                android:ellipsize="end"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_6"
                android:paddingTop="@dimen/vs_2"
                android:paddingRight="@dimen/vs_6"
                android:paddingBottom="@dimen/vs_2"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_18" />

            <!-- 标题 -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:gravity="start|center_vertical"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:textColor="@color/color_FFFFFF"
                android:textSize="@dimen/ts_20"
                android:textStyle="bold"
                android:shadowColor="@color/color_000000_90"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
